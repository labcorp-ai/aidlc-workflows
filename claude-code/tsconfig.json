{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowImportingTsExtensions": true,
    "types": ["bun-types"]
  },
  "include": [
    "dist/claude/.claude/hooks/*.ts",
    "dist/claude/.claude/tools/*.ts",
    "dist/claude/.claude/tools/data/*.json"
  ]
}
