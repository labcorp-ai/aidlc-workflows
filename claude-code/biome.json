{
  "$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
  "formatter": {
    "enabled": false
  },
  "linter": {
    "enabled": true
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "off"
      }
    }
  },
  "files": {
    "includes": ["**", "!tests/fixtures/**"]
  },
  "overrides": [
    {
      "includes": ["tests/**"],
      "linter": {
        "rules": {
          "style": {
            "noNonNullAssertion": "off"
          }
        }
      }
    },
    {
      "includes": ["dist/claude/.claude/tools/**"],
      "linter": {
        "rules": {
          "style": {
            "noNonNullAssertion": "off",
            "useTemplate": "off"
          }
        }
      }
    }
  ]
}
